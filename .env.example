# ── Ubique Pay environment ─────────────────────────────────────────────
# Copy to .env (git-ignored). The app loads it automatically (python-dotenv).

# ── Core (REQUIRED in production) ──────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
# Dev defaults below; in production set DJANGO_DEBUG=0 and the domain:
#   DJANGO_DEBUG=0
#   DJANGO_ALLOWED_HOSTS=ubique.ubermensch.cc
#   DJANGO_CSRF_TRUSTED_ORIGINS=https://ubique.ubermensch.cc
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_CORS_ALLOWED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=1

# Field-level encryption keys (Fernet); first is primary, extras enable rotation.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
UBIQUE_FIELD_KEYS=

# ── Database (sqlite by default; set DB_NAME to switch to PostgreSQL) ───
# DB_NAME=ubique
# DB_USER=ubique
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# ── Economics ──────────────────────────────────────────────────────────
UBIQUE_COMMISSION_RATE=0.005     # Ubique commission (0.5%)
UBIQUE_FX_SPREAD=0.005           # FX spread on top of mid-market (0.5%)
UBIQUE_ONRAMP_FEE_RATE=0.02      # card acquiring (pay-in) cost (~2%)
UBIQUE_PAYOUT_FEE_RATE=0.01      # push-to-card (pay-out) cost (~1%)
UBIQUE_MIN_SEND=20
UBIQUE_MAX_SEND=10000
UBIQUE_MAX_DAILY=20000
# Block payouts when the receive-currency float is insufficient (treasury).
UBIQUE_LIQUIDITY_ENFORCED=0
# TON-first (Telegram-native). The router picks the cheapest listed network —
# add SOLANA to widen routing: UBIQUE_NETWORKS=TON,TRON,SOLANA
UBIQUE_NETWORKS=TON,TRON
# Comma-separated phones / card-last4 to block (sanctions/compliance demo).
UBIQUE_DENYLIST=

# ── Webhook signing secrets (verify X-Ubique-Signature = HMAC-SHA256) ───
ONRAMP_WEBHOOK_SECRET=
PAYOUT_WEBHOOK_SECRET=
# Retries before an event is dead-lettered (run: manage.py retry_webhooks).
UBIQUE_MAX_WEBHOOK_ATTEMPTS=5

# ── FX (multi-source, cached) ──────────────────────────────────────────
UBIQUE_FX_CACHE_TTL=60
# UBIQUE_FX_SOURCES=ubique.providers.fx.SourceA,ubique.providers.fx.SourceB

# ── Anti-abuse ─────────────────────────────────────────────────────────
UBIQUE_OTP_MAX_PER_HOUR=5
UBIQUE_OTP_MAX_ATTEMPTS=5

# ── Telegram Mini App + bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Public https URL of this app (Mini App + TON Connect manifest live here).
# Production: https://ubique.ubermensch.cc
PUBLIC_BASE_URL=http://localhost:8000

# ── Providers (default = mocks; point at real adapters in production) ───
# UBIQUE_ONRAMP=ubique.providers.real.TransakOnRampProvider
# UBIQUE_CHAIN_SENDER=ubique.providers.real.TonChainSender
# UBIQUE_PAYOUT=ubique.providers.real.VisaDirectPayoutProvider

# Real on-ramp (Transak) — card → USDT-TON to the treasury wallet.
# TRANSAK_API_KEY=
# TRANSAK_ENV=STAGING
# UBIQUE_TREASURY_WALLET=

# Real TON chain sender (tonutils) — 24-word mnemonic of the treasury wallet.
# Create one: python manage.py ton_wallet --create  (fund via @testgiver_ton_bot)
# TON_MNEMONIC=
# TON_API_KEY=
# TON_TESTNET=1
# TON_USDT_MASTER=          # override the USDT jetton master for testnet/test jettons

# ── Multisig treasury ──────────────────────────────────────────────────
# On-chain moves >= MIN_USDT need THRESHOLD approvals from treasury signers
# (mark users is_treasury_signer in the admin) before the USDT is broadcast.
UBIQUE_MULTISIG_ENABLED=0
UBIQUE_MULTISIG_THRESHOLD=2
UBIQUE_MULTISIG_MIN_USDT=1000
# Optional on-chain TON Multisig contract address for the treasury wallet.
# TON_MULTISIG_ADDRESS=

# ── KYC ────────────────────────────────────────────────────────────────
# Demo auto-verifies; switch to Sumsub in production.
KYC_PROVIDER=ubique.accounts.kyc.DemoKycProvider
# KYC_PROVIDER=ubique.accounts.kyc.SumsubKycProvider
# SUMSUB_APP_TOKEN=
# SUMSUB_SECRET_KEY=
# SUMSUB_LEVEL_NAME=basic-kyc-level
# SUMSUB_WEBHOOK_SECRET=

# ── Deployment (used by deploy.py) ─────────────────────────────────────
DEPLOY_DOMAIN=ubique.ubermensch.cc
DEPLOY_APP_NAME=ubique-pay
GUNICORN_WORKERS=3
GUNICORN_BIND=unix:/run/ubique-pay.sock
